{
  "name": "douyin-blood-bar",
  "version": "1.0.0",
  "description": "抖音直播血条插件 - 根据礼物实时增减血条",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --mac"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.douyin.bloodbar",
    "productName": "抖音血条插件",
    "win": {
      "target": "portable"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
